#compdef srs

_srs() {
    local -a commands
    commands=(
        'sync:Fetch words from Speakly'
        'review:Start review session'
        'stats:Show learning statistics'
        'browse:Browse/search word bank'
        'config:Manage settings'
        'notify:Manage review reminders'
    )

    _arguments -C \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe 'command' commands
            ;;
        args)
            case $words[1] in
                sync)
                    _arguments \
                        '--from-file[Import from JSON file]:file:_files -g "*.json"' \
                        '--full[Fetch all pages without early stopping]' \
                        '(-h --help)'{-h,--help}'[Show help]'
                    ;;
                browse)
                    _arguments \
                        '*:query:' \
                        '(-h --help)'{-h,--help}'[Show help]'
                    ;;
                review|stats)
                    _arguments \
                        '(-h --help)'{-h,--help}'[Show help]'
                    ;;
                config)
                    local -a config_commands
                    config_commands=(
                        'typing:Toggle typing mode (on/off)'
                        'skip-new-today:Skip cards added today in reviews (on/off)'
                    )
                    _arguments -C \
                        '1:config command:->config_command' \
                        '*::config arg:->config_args'
                    case $state in
                        config_command)
                            _describe 'config command' config_commands
                            ;;
                        config_args)
                            case $words[1] in
                                typing|skip-new-today)
                                    _arguments \
                                        '1:value:(on off)'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                notify)
                    local -a notify_commands
                    notify_commands=(
                        'on:Enable notifications'
                        'off:Disable notifications'
                        'status:Show notification settings'
                    )
                    _arguments -C \
                        '1:notify command:->notify_command' \
                        '*::notify arg:->notify_args'
                    case $state in
                        notify_command)
                            _describe 'notify command' notify_commands
                            ;;
                        notify_args)
                            case $words[1] in
                                on)
                                    _arguments \
                                        '*--at[Reminder time (HH\:MM)]:time:' \
                                        '--dry-run[Fire notification now without installing]' \
                                        '(-h --help)'{-h,--help}'[Show help]'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac
}

_srs "$@"
